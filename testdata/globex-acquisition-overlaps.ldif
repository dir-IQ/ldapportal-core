# =============================================================================
# Globex acquisition overlaps — curated demo personas.
#
# This is a thin scenarios layer on top of globex-250-users.ldif. The bulk file
# already exercises every cross-directory tier statistically (75 EXACT, 25 HIGH,
# 10 AMBIGUOUS, 140 Globex-only); this file adds a handful of NAMED users that
# are easy to point at during a demo or assert on in an integration test.
#
# Schema: stock inetOrgPerson only. AD-shape concepts ride in employeeType +
# description annotations (see README-globex.md).
#
# Load order:
#   1. testdata/acmecorp-5000-users.ldif
#   2. testdata/globex-250-users.ldif
#   3. testdata/globex-acquisition-overlaps.ldif    (this file)
# =============================================================================


# ── Demo persona: clean EXACT-tier ─────────────────────────────────────────
# Joins to acmecorp/jack.roberts (EMP000100, jack.roberts@acmecorp.com) by
# primary key (mail).

dn: uid=glx-demo-exact,ou=Engineering,ou=People,dc=globex,dc=com
objectClass: top
objectClass: inetOrgPerson
objectClass: organizationalPerson
objectClass: person
uid: glx-demo-exact
cn: Jack Roberts
givenName: Jack
sn: Roberts
displayName: Jack Roberts (Globex)
mail: jack.roberts@acmecorp.com
employeeNumber: EMP000100
employeeType: Full-Time
title: Engineering Manager (post-acquisition)
ou: Engineering
l: London
description: DEMO — EXACT-tier joiner (mail match to acmecorp/jack.roberts)
userPassword: {SSHA}placeholder


