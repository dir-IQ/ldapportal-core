# ── Groups ─────────────────────────────────────────────────────────────────
# Engineering team — flat membership.
dn: cn=engineering,ou=groups,dc=oudtest,dc=example,dc=com
objectClass: top
objectClass: groupOfUniqueNames
cn: engineering
description: Engineering team — all engineers and engineering managers.
uniqueMember: uid=alice.smith,ou=people,dc=oudtest,dc=example,dc=com
uniqueMember: uid=bob.jones,ou=people,dc=oudtest,dc=example,dc=com
uniqueMember: uid=carol.davis,ou=people,dc=oudtest,dc=example,dc=com
uniqueMember: uid=david.lee,ou=people,dc=oudtest,dc=example,dc=com
uniqueMember: uid=eve.martinez,ou=people,dc=oudtest,dc=example,dc=com

# Design team — flat membership.
dn: cn=design,ou=groups,dc=oudtest,dc=example,dc=com
objectClass: top
objectClass: groupOfUniqueNames
cn: design
description: Design team — designers and the design manager.
uniqueMember: uid=frank.nguyen,ou=people,dc=oudtest,dc=example,dc=com
uniqueMember: uid=grace.oconnor,ou=people,dc=oudtest,dc=example,dc=com
uniqueMember: uid=henry.park,ou=people,dc=oudtest,dc=example,dc=com
uniqueMember: uid=isabel.quinn,ou=people,dc=oudtest,dc=example,dc=com

# Nested aggregate — members are the two team-level groups, not users.
# Exercises P4: a search for entries where `isMemberOf` contains
# cn=allTechStaff should resolve every engineering + design user, even
# though no user is a direct uniqueMember of cn=allTechStaff.
dn: cn=allTechStaff,ou=groups,dc=oudtest,dc=example,dc=com
objectClass: top
objectClass: groupOfUniqueNames
cn: allTechStaff
description: All tech staff (engineering + design) — nested group.
uniqueMember: cn=engineering,ou=groups,dc=oudtest,dc=example,dc=com
uniqueMember: cn=design,ou=groups,dc=oudtest,dc=example,dc=com
