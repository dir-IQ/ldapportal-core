# ── Nested group (ibm-nestedGroup) ──────────────────────────────────────────
# Two existing static groups (engineering + design) referenced via
# ibm-memberGroup. ITDS resolves ibm-allMembers server-side as the union
# of the leaf member entries from each referenced group. Exercises the
# Phase 4 code path in LdapGroupService.getNestedMembers when the
# directory type is IBM_DIRECTORY_SERVER.
dn: cn=allTechStaff,ou=groups,dc=itdstest,dc=example,dc=com
objectClass: top
objectClass: groupOfNames
objectClass: ibm-nestedGroup
cn: allTechStaff
description: All technical staff (engineering + design) — uses ibm-nestedGroup
ibm-memberGroup: cn=engineering,ou=groups,dc=itdstest,dc=example,dc=com
ibm-memberGroup: cn=design,ou=groups,dc=itdstest,dc=example,dc=com
# groupOfNames requires at least one 'member' attribute in standard schema;
# the bootstrap group's owner / placeholder member is repeated for that.
member: uid=bob.johnson,ou=people,dc=itdstest,dc=example,dc=com

# ── Dynamic group (ibm-dynamicGroup) ────────────────────────────────────────
# memberURL is the standard LDAP URL syntax. Anyone whose title matches
# *Engineer* (case-insensitive substring) is a member. ITDS resolves this
# server-side and includes the resolved members in ibm-allMembers responses.
dn: cn=allEngineers,ou=groups,dc=itdstest,dc=example,dc=com
objectClass: top
objectClass: groupOfURLs
objectClass: ibm-dynamicGroup
cn: allEngineers
description: All entries with 'Engineer' in title — dynamic-group via memberURL
memberURL: ldap:///ou=people,dc=itdstest,dc=example,dc=com??sub?(title=*Engineer*)
