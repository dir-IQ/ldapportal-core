# =============================================================================
# LDIF Test Data — ITDS test fixture (~20 users, 5 groups)
# Base DN: dc=itdstest,dc=example,dc=com
#
# Loaded on first volume init by the ldap-itds compose service. Designed to
# exercise the ITDS-specific code paths from the P2-P5 phases of
# docs/superpowers/plans/2026-05-11-ibm-directory-server-support.md:
#
#   - Standard inetOrgPerson entries (P1 generic path)
#   - groupOfNames static groups (P4 baseline)
#   - ibm-nestedGroup with two member groups (P4 ibm-allMembers path)
#   - ibm-dynamicGroup with a memberURL filter (P4 dynamic-group resolution
#     and the deferred-but-visible Phase 5 work)
#
# Bind DN for the admin: cn=root (set in the docker-compose env).
# =============================================================================

# ── Base DN ─────────────────────────────────────────────────────────────────
dn: dc=itdstest,dc=example,dc=com
objectClass: top
objectClass: domain
dc: itdstest

# ── Organisational units ────────────────────────────────────────────────────
dn: ou=people,dc=itdstest,dc=example,dc=com
objectClass: top
objectClass: organizationalUnit
ou: people

dn: ou=groups,dc=itdstest,dc=example,dc=com
objectClass: top
objectClass: organizationalUnit
ou: groups

# ── Users (8 engineers, 4 designers, 4 PMs, 4 misc) ─────────────────────────
