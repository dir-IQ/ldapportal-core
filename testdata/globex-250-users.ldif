# =============================================================================
# Globex — 250-user AD-flavoured LDIF for cross-directory testing.
#
# Generated by testdata/generate-globex.py (deterministic; seed=0xACE0F1E1).
# Suffix: dc=globex,dc=com   (sibling to dc=acmecorp,dc=com)
#
# Composition:
#    75 EXACT-tier overlaps  — same mail as an acmecorp user
#    25 HIGH-tier overlaps   — same employeeNumber, different mail domain
#    10 AMBIGUOUS pairs      — 5 collisions × 2 (dup employeeNumber)
#   140 Globex-only          — no acmecorp counterpart
#
# AD-shape concepts (UAC=514 disabled, UAC=66048 service-account,
# pwdLastSet=0 must-change, accountExpires past) are encoded into stock
# inetOrgPerson attributes (employeeType + description annotations) so
# the file loads into unmodified OpenLDAP. To use real AD attributes,
# load a samba/AD schema and run a transform pass on this file.
#
# Load order (after acmecorp-5000-users.ldif):
#   ldapadd -x -D <admin-dn> -w <pw> -f testdata/globex-250-users.ldif
#   ldapmodify -x -D <admin-dn> -w <pw> -a -f testdata/globex-acquisition-overlaps.ldif
#
# Note: the suffix root entry (dc=globex,dc=com) is intentionally NOT
# included here. osixia/openldap auto-creates it from LDAP_DOMAIN at
# container init. Defining it again would make ldapadd return code 68
# (Already exists) and abort the bootstrap, leaving the directory empty.
# =============================================================================

dn: ou=People,dc=globex,dc=com
objectClass: top
objectClass: organizationalUnit
ou: People
description: Active and inactive Globex personnel

dn: ou=Groups,dc=globex,dc=com
objectClass: top
objectClass: organizationalUnit
ou: Groups
description: Globex security and distribution groups

dn: ou=ServiceAccounts,dc=globex,dc=com
objectClass: top
objectClass: organizationalUnit
ou: ServiceAccounts
description: Globex service / non-human accounts

dn: ou=Engineering,ou=People,dc=globex,dc=com
objectClass: top
objectClass: organizationalUnit
ou: Engineering
description: Globex Engineering department

dn: ou=Sales,ou=People,dc=globex,dc=com
objectClass: top
objectClass: organizationalUnit
ou: Sales
description: Globex Sales department

dn: ou=Marketing,ou=People,dc=globex,dc=com
objectClass: top
objectClass: organizationalUnit
ou: Marketing
description: Globex Marketing department

dn: ou=Operations,ou=People,dc=globex,dc=com
objectClass: top
objectClass: organizationalUnit
ou: Operations
description: Globex Operations department

dn: ou=Finance,ou=People,dc=globex,dc=com
objectClass: top
objectClass: organizationalUnit
ou: Finance
description: Globex Finance department

# ══════════════════════════════════════════════════════════════════════
