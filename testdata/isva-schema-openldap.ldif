# SPDX-License-Identifier: Apache-2.0
# IVIA test-fixture ISVA/ISAM schema — OpenLDAP cn=config form.
#
# Loaded into the openldap-primary / openldap-alternate fixtures by
# osixia/openldap's schema bootstrap (files under
# /container/service/slapd/assets/config/bootstrap/schema/ are added to
# cn=config on first volume init). Minimal subset the IVIA addon actually
# reads/writes: the secUser account overlay + the secAuthorityInfo base.
#
# Private-arc OIDs (1.3.6.1.4.1.99999.*) — fixture only; not IBM's real
# registered OIDs. Names match what the app uses; OIDs are irrelevant to it.
#
# Manual fallback (if the bootstrap didn't pick it up):
#   docker exec ldap-openldap-primary \
#     ldapadd -Y EXTERNAL -H ldapi:/// -f /path/inside/container/isva-schema-openldap.ldif

dn: cn=isva-test,cn=schema,cn=config
objectClass: olcSchemaConfig
cn: isva-test
olcAttributeTypes: ( 1.3.6.1.4.1.99999.1.1.1 NAME 'secLogin'
  DESC 'IVIA test fixture: login name within secAuthority'
  EQUALITY caseIgnoreMatch
  SUBSTR caseIgnoreSubstringsMatch
  SYNTAX 1.3.6.1.4.1.1466.115.121.1.15{255}
  SINGLE-VALUE )
olcAttributeTypes: ( 1.3.6.1.4.1.99999.1.1.2 NAME 'secAuthority'
  DESC 'IVIA test fixture: authority / policy domain'
  EQUALITY caseIgnoreMatch
  SYNTAX 1.3.6.1.4.1.1466.115.121.1.15{255}
  SINGLE-VALUE )
olcAttributeTypes: ( 1.3.6.1.4.1.99999.1.1.3 NAME 'secAcctValid'
  DESC 'IVIA test fixture: TRUE when the account is valid'
  EQUALITY caseIgnoreMatch
  SYNTAX 1.3.6.1.4.1.1466.115.121.1.15{5}
  SINGLE-VALUE )
olcAttributeTypes: ( 1.3.6.1.4.1.99999.1.1.4 NAME 'secPwdValid'
  DESC 'IVIA test fixture: TRUE when the password is valid'
  EQUALITY caseIgnoreMatch
  SYNTAX 1.3.6.1.4.1.1466.115.121.1.15{5}
  SINGLE-VALUE )
olcAttributeTypes: ( 1.3.6.1.4.1.99999.1.1.5 NAME 'secValidUntil'
  DESC 'IVIA test fixture: generalized time the account ceases to be valid'
  EQUALITY generalizedTimeMatch
  ORDERING generalizedTimeOrderingMatch
  SYNTAX 1.3.6.1.4.1.1466.115.121.1.24
  SINGLE-VALUE )
olcAttributeTypes: ( 1.3.6.1.4.1.99999.1.1.6 NAME 'secPwdLastChanged'
  DESC 'IVIA test fixture: generalized time the password was last changed'
  EQUALITY generalizedTimeMatch
  ORDERING generalizedTimeOrderingMatch
  SYNTAX 1.3.6.1.4.1.1466.115.121.1.24
  SINGLE-VALUE )
olcAttributeTypes: ( 1.3.6.1.4.1.99999.1.1.7 NAME 'secDN'
  DESC 'IVIA test fixture: back-reference DN of the paired demographic (linked mode)'
  EQUALITY distinguishedNameMatch
  SYNTAX 1.3.6.1.4.1.1466.115.121.1.12
  SINGLE-VALUE )
olcAttributeTypes: ( 1.3.6.1.4.1.99999.1.1.8 NAME 'secUUID'
  DESC 'IVIA test fixture: opaque identifier for the secUser entry'
  EQUALITY caseIgnoreMatch
  SYNTAX 1.3.6.1.4.1.1466.115.121.1.15{255}
  SINGLE-VALUE )
olcObjectClasses: ( 1.3.6.1.4.1.99999.1.2.1 NAME 'secUser'
  DESC 'IVIA test fixture: account overlay (AUXILIARY here; IBM ships STRUCTURAL)'
  SUP top AUXILIARY
  MAY ( secLogin $ secAuthority $ secAcctValid $ secPwdValid $
        secValidUntil $ secPwdLastChanged $ secDN $ secUUID ) )

dn: cn=isva-secauthority,cn=schema,cn=config
objectClass: olcSchemaConfig
cn: isva-secauthority
olcObjectClasses: ( 1.3.6.1.4.1.99999.1.2.2 NAME 'secAuthorityInfo'
  DESC 'IVIA test fixture: structural class for the management-DIT base entry whose RDN is secAuthority=...'
  SUP top STRUCTURAL
  MUST ( secAuthority ) )
