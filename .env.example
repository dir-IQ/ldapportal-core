# Copy this file to .env and fill in all values before starting with docker-compose.
# Never commit .env to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=ldapportal
POSTGRES_USER=ldapportal
POSTGRES_PASSWORD=change_me

# ── Encryption key (AES-256) ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
# JWT_EXPIRY_MINUTES=60

# ── Bootstrap superadmin (invalidated after first permanent superadmin is created)
BOOTSTRAP_SUPERADMIN_USERNAME=superadmin
BOOTSTRAP_SUPERADMIN_PASSWORD=REPLACE_WITH_STRONG_TEMP_PASSWORD

# ── Approval workflow ─────────────────────────────────────────────────────────
# Auto-approve requests submitted by superadmins. Config-only (not editable in
# the UI) so a superadmin cannot grant themselves the bypass. Default false.
# APP_APPROVAL_SUPERADMIN_BYPASS=false

# ── Authentication tab visibility ─────────────────────────────────────────────
# Whether the OIDC / WebSEAL enable toggle + config block appear in the
# Authentication settings tab. UI visibility only — does not change auth
# behavior (enablement comes from the persisted settings). Defaults: WebSEAL
# shown, OIDC hidden.
# APP_AUTH_OIDC_UI_VISIBLE=false
# APP_AUTH_WEBSEAL_UI_VISIBLE=true

# ── ISVA integration (community-plus-isva / commercial only) ──────────────────
# Which topology modes the ISVA integration config page offers. UI only — does
# not restrict what the config API accepts. Comma-separated subset of:
# inline, linked. When only one is listed the topology-mode selector is hidden
# and that mode is pinned. Default: linked.
# APP_ISVA_EXPOSED_TOPOLOGY_MODES=linked

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
APP_LOG_LEVEL=INFO
